classDiagram

class Grupo {
    -nombre: String
    -amigos: List~Amigo~
    -eventos: List~Evento~
    +agregarAmigo(amigo: Amigo)
    +crearEvento(fecha: Date, lugar: String): Evento
}

class Amigo {
    -nombre: String
    -instrumentos: List~Instrumento~
    -instrumentoPrincipal: Instrumento
    -probabilidadAsistir: double
    +agregarInstrumento(instrumento: Instrumento)
    +setInstrumentoPrincipal(instrumento: Instrumento)
    +decidirAsistencia(): boolean
}

class Instrumento {
    -nombre: String
    -tipo: String
}

class Evento {
    -fecha: Date
    -lugar: String
    -participantes: List~Amigo~
    +agregarParticipante(amigo: Amigo)
}

